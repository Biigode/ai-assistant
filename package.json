{
  "name": "daily-digest",
  "version": "2.0.0",
  "description": "Daily news digest via Telegram com LLM local + cloud e pipeline de agentes",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "polling": "tsx src/telegram/polling.ts",
    "queue:message-handler": "node dist/queue-workers/message-handler.js",
    "queue:intent": "node dist/queue-workers/intent.js",
    "queue:search": "node dist/queue-workers/search.js",
    "queue:response": "node dist/queue-workers/response.js",
    "queue:sender": "node dist/queue-workers/telegram-sender.js"
  },
  "dependencies": {
    "amqplib": "^0.10.9",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "inquirer": "^9.2.20",
    "mongodb": "^7.1.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "node-telegram-bot-api": "^0.67.0",
    "ollama": "^0.5.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
