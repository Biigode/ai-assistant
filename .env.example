# =============================================
#  DAILY DIGEST - Configurações de Ambiente
#  Copie este arquivo para .env e preencha os valores
# =============================================

# --- MongoDB ---
MONGODB_URI=mongodb://mongodb:27017/ai-assistant
MONGODB_DATABASE=ai-assistant

# --- Telegram Bot ---
# Crie um bot em @BotFather no Telegram e cole o token abaixo
TELEGRAM_BOT_TOKEN=seu_token_aqui

# --- Ollama Local (sempre ativo, sem key) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# --- Ollama API Key (única — cloud + web search) ---
# Crie conta em https://ollama.com → Settings → API Keys
OLLAMA_API_KEY=
OLLAMA_CLOUD_URL=https://ollama.com

# --- Modelos cloud (usam a OLLAMA_API_KEY acima) ---
# Raciocínio profundo: agentes, briefings, análise
OLLAMA_MODEL_REASONING=gpt-oss:20b-cloud
# Chat e digest: tarefas simples e econômicas
OLLAMA_MODEL_CHAT=qwen3.5:4b-cloud

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# --- Agendamento ---
# Exemplos: '0 8 * * *' = 08h diário | '0 * * * *' = toda hora
CRON_SCHEDULE=0 8 * * *
TIMEZONE=America/Sao_Paulo
