# =============================================
#  DAILY DIGEST - Configurações de Ambiente
# =============================================

# --- MongoDB Atlas ---
# Crie conta gratuita em: https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/daily-digest?retryWrites=true&w=majority

# --- Telegram Bot ---
# Instruções:
# 1. Crie um bot em: @BotFather (use /newbot)
# 2. Copie o bot token
# 3. Descubra seu Chat ID: @userinfobot (envie qualquer mensagem)
TELEGRAM_BOT_TOKEN=seu_bot_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# --- Ollama (LLM Local) ---
# Modelo recomendado: llama3.2:3b (ou llama3.2:1b para menos recursos)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# --- Ollama Web Search API ---
# Obtenha sua chave em: https://ollama.com/api/web_search
OLLAMA_API_KEY=sua_chave_aqui

# --- Agendamento ---
# Formato cron: "0 8 * * *" = todo dia às 8h
CRON_SCHEDULE=0 8 * * *
TIMEZONE=America/Sao_Paulo
